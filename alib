        Font = FONT_BOLD,
        Text = ">",
        TextSize = 14,
        Parent = frame,
    })
    Theme(arrow, "TextColor3", "DimText")

    makeInteractive(frame, function()
        SafeCallback(cfg.Callback)
    end)

    local api = {}
    attachCommon(api, frame, label)
    return api
end

local function createToggle(tab, cfg)
    cfg = cfg or {}
    local state = cfg.Default and true or false

    local frame = newElementFrame(tab, 36)
    frame.Name = "Toggle"
    local label = elementLabel(frame, cfg.Name or "Toggle")
    label.Size = UDim2.new(1, -66, 1, 0)

    local pill = Create("Frame", {
        Size = UDim2.new(0, 40, 0, 22),
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, -12, 0.5, 0),
        BorderSizePixel = 0,
        Parent = frame,
    })
    AddCorner(pill, 11)
    local knob = Create("Frame", {
        Size = UDim2.new(0, 16, 0, 16),
        AnchorPoint = Vector2.new(0, 0.5),
        Position = UDim2.new(0, 3, 0.5, 0),
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        BorderSizePixel = 0,
        Parent = pill,
    })
    AddCorner(knob, 8)

    local function refresh(animate)
        if pill.Parent == nil then
            return
        end
        local pillColor = state and resolveColor("Accent") or resolveColor("ToggleOff")
        local knobPos = state and UDim2.new(1, -19, 0.5, 0) or UDim2.new(0, 3, 0.5, 0)
        if animate then
            Tween(pill, { BackgroundColor3 = pillColor }, 0.15)
            Tween(knob, { Position = knobPos }, 0.15)
        else
            pill.BackgroundColor3 = pillColor
            knob.Position = knobPos
        end
    end
    refresh(false)
    addRefresher(function() refresh(false) end)

    makeInteractive(frame, function()
        state = not state
        refresh(true)
        SafeCallback(cfg.Callback, state)
    end)

    local api = {}
    function api:Set(v)
        state = v and true or false
        refresh(true)
        SafeCallback(cfg.Callback, state)
        return api
    end
    function api:Get()
        return state
    end
    attachCommon(api, frame, label)

    SafeCallback(cfg.Callback, state) -- apply default
    return api
end

