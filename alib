        kc = (typeof(cfg.Default) == "EnumItem") and cfg.Default or nil,
    }

    local keyBtn = Create("TextButton", {
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, -12, 0.5, 0),
        Size = UDim2.new(0, 84, 0, 24),
        BorderSizePixel = 0,
        AutoButtonColor = false,
        Font = FONT_MED,
        TextSize = 12,
        Text = "None",
        Parent = frame,
    })
    Theme(keyBtn, "BackgroundColor3", "Section")
    Theme(keyBtn, "TextColor3", "Text")
    AddCorner(keyBtn, 6)
    AddStroke(keyBtn)
    hoverFrame(keyBtn, keyBtn)

    function kb.render()
        if keyBtn.Parent == nil then
            return
        end
        if kb.listening then
            keyBtn.Text = "..."
        elseif typeof(kb.kc) == "EnumItem" then
            keyBtn.Text = kb.kc.Name
        else
            keyBtn.Text = "None"
        end
    end
    function kb.fire()
        SafeCallback(cfg.Callback)
    end
    kb.render()
    table.insert(Library._keybinds, kb)

    Connect(keyBtn.Activated, function()
        if IS_MOBILE then
            Library:Notify({
                Title = "Keybind",
                Content = "A physical keyboard is required to set a keybind.",
                Type = "info",
                Duration = 2,
            })
            return
        end
        kb.listening = true
        kb.render()
    end)

    local api = {}
    function api:Set(k)
        kb.kc = (typeof(k) == "EnumItem") and k or nil
        kb.render()
        return api
    end
    function api:Get()
        return kb.kc
    end
    attachCommon(api, frame, label, function()
        for i, v in ipairs(Library._keybinds) do
            if v == kb then
                table.remove(Library._keybinds, i)
                break
            end
        end
    end)
    return api
end

