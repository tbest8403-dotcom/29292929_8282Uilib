        function tab:CreateParagraph(c)   return createParagraph(self, c) end
        function tab:CreateSection(n)     return createSection(self, n) end
        function tab:CreateDivider()      return createDivider(self) end

        table.insert(self._tabs, tab)
        self._tabsByName[name] = tab
        if #self._tabs == 1 then
            self:SelectTab(name)
        end
        return tab
    end

    function Window:SelectTab(name)
        local target = self._tabsByName[tostring(name)]
        if not target then
            return
        end
        for _, t in ipairs(self._tabs) do
            t:_setSelected(t == target)
        end
        self._activeTab = target
        return target
    end

    function Window:GetTab(name)
        return self._tabsByName[tostring(name)]
    end

    function Window:DeleteTab(name)
        name = tostring(name)
        local t = self._tabsByName[name]
        if not t then
            return
        end
        for i, v in ipairs(self._tabs) do
            if v == t then
                table.remove(self._tabs, i)
                break
            end
        end
        self._tabsByName[name] = nil
        pcall(function() t._button:Destroy() end)
        pcall(function() t._pageInst:Destroy() end)
        if self._activeTab == t then
            self._activeTab = nil
            if self._tabs[1] then
                self:SelectTab(self._tabs[1]._name)
            end
        end
    end

