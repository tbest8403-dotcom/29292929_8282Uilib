        setOpen(not open)
    end)

    rebuildColor(false)
    setOpen(false)
    SafeCallback(cfg.Callback, color) -- apply default

    local api = {}
    function api:Set(c)
        if typeof(c) == "Color3" then
            h, s, v = c:ToHSV()
            rebuildColor(true)
        end
        return api
    end
