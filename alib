local function createButton(tab, cfg)
    cfg = cfg or {}
    local frame = newElementFrame(tab, 36)
    frame.Name = "Button"
    local label = elementLabel(frame, cfg.Name or "Button")
    label.Size = UDim2.new(1, -40, 1, 0)

    local arrow = Create("TextLabel", {
        BackgroundTransparency = 1,
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, -12, 0.5, 0),
