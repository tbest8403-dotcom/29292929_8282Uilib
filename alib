            oScale.Scale = sc
        end
        scaleOverlay()
        if workspace.CurrentCamera then
            Connect(workspace.CurrentCamera:GetPropertyChangedSignal("ViewportSize"), scaleOverlay)
        end

        local kTitle = Create("TextLabel", {
            BackgroundTransparency = 1,
            Position = UDim2.new(0, 0, 0, 16),
            Size = UDim2.new(1, 0, 0, 22),
            Font = FONT_BOLD,
            Text = "Key System",
            TextSize = 18,
            Parent = overlay,
        })
        Theme(kTitle, "TextColor3", "Text")
        local kSub = Create("TextLabel", {
            BackgroundTransparency = 1,
            Position = UDim2.new(0, 18, 0, 42),
            Size = UDim2.new(1, -36, 0, 18),
            Font = FONT,
            Text = "Enter your key to continue.",
            TextSize = 12,
            Parent = overlay,
        })
        Theme(kSub, "TextColor3", "SubText")

        local inputBox = Create("Frame", {
            Position = UDim2.new(0, 18, 0, 72),
            Size = UDim2.new(1, -36, 0, 34),
            BorderSizePixel = 0,
            Parent = overlay,
        })
        Theme(inputBox, "BackgroundColor3", "Element")
        AddCorner(inputBox, 8)
        local inputStroke = AddStroke(inputBox)
        local keyInput = Create("TextBox", {
            BackgroundTransparency = 1,
            Position = UDim2.new(0, 10, 0, 0),
            Size = UDim2.new(1, -20, 1, 0),
            Font = FONT,
            Text = "",
            PlaceholderText = "Key...",
            TextSize = 13,
            TextXAlignment = Enum.TextXAlignment.Left,
            ClearTextOnFocus = false,
            ClipsDescendants = true,
            Parent = inputBox,
        })
        Theme(keyInput, "TextColor3", "Text")
        Theme(keyInput, "PlaceholderColor3", "DimText")

        local submitBtn = Create("TextButton", {
            Position = UDim2.new(0, 18, 0, 116),
            Size = UDim2.new(1, -36, 0, 34),
            BorderSizePixel = 0,
            AutoButtonColor = false,
            Font = FONT_BOLD,
            Text = "Submit",
            TextSize = 14,
            Parent = overlay,
        })
        Theme(submitBtn, "BackgroundColor3", "Accent")
        Theme(submitBtn, "TextColor3", "AccentText")
        AddCorner(submitBtn, 8)

        local statusLbl = Create("TextLabel", {
            BackgroundTransparency = 1,
            Position = UDim2.new(0, 18, 0, 154),
            Size = UDim2.new(1, -36, 0, 16),
            Font = FONT_MED,
            Text = "",
            TextSize = 12,
            TextXAlignment = Enum.TextXAlignment.Center,
            Parent = overlay,
        })
        Theme(statusLbl, "TextColor3", "Error")

        if hasDiscord then
            local copyBtn = Create("TextButton", {
                Position = UDim2.new(0, 18, 0, 178),
                Size = UDim2.new(1, -36, 0, 30),
                BorderSizePixel = 0,
                AutoButtonColor = false,
                Font = FONT_MED,
                Text = "Copy Discord",
                TextSize = 13,
                Parent = overlay,
            })
            Theme(copyBtn, "BackgroundColor3", "Element")
            Theme(copyBtn, "TextColor3", "Text")
            AddCorner(copyBtn, 8)
            AddStroke(copyBtn)
            hoverFrame(copyBtn, copyBtn)
            Connect(copyBtn.Activated, function()
                Library:CopyToClipboard(discord)
            end)
        end

        Connect(submitBtn.MouseEnter, function()
            Tween(submitBtn, { BackgroundColor3 = resolveColor("Accent"):Lerp(Color3.new(1, 1, 1), 0.12) }, 0.15)
        end)
        Connect(submitBtn.MouseLeave, function()
            Tween(submitBtn, { BackgroundColor3 = resolveColor("Accent") }, 0.15)
        end)

        local function trySubmit()
            local entered = keyInput.Text
            entered = entered:gsub("^%s+", ""):gsub("%s+$", "")
            local ok = false
            for _, k in ipairs(keys) do
                if tostring(k) == entered then
                    ok = true
                    break
                end
            end
            if ok then
                keyPending = false
                Tween(oScale, { Scale = 0 }, 0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
                Tween(overlay, { BackgroundTransparency = 1 }, 0.2)
                task.delay(0.22, function()
                    pcall(function() overlay:Destroy() end)
                end)
                Window.ShowUI()
                Library:Notify({
                    Title = "Welcome",
                    Content = "Key accepted.",
                    Type = "success",
                    Duration = 2,
                })
            else
                statusLbl.Text = "Incorrect key."
                statusLbl.Visible = true
                Tween(inputStroke, { Color = resolveColor("Error") }, 0.15)
                task.delay(1.2, function()
                    pcall(function()
                        Tween(inputStroke, { Color = resolveColor("Stroke") }, 0.2)
                    end)
                end)
            end
        end

        Connect(submitBtn.Activated, trySubmit)
        Connect(keyInput.FocusLost, function(enterPressed)
            if enterPressed then
                trySubmit()
            end
        end)
    end

    if genv then
        genv.__ModernUILib = Library
    end

    return Window
end

----------------------------------------------------------------------------
-- Library-level methods
----------------------------------------------------------------------------
function Library:SetTheme(name)
    if Themes[name] then
        Library._themeName = name
        Library._theme = Themes[name]
        ApplyTheme()
    end
    return Library._themeName
end

function Library:GetTheme()
    return Library._themeName
end

function Library:SetAccentColor(color)
    if typeof(color) == "Color3" then
        Library._accent = color
        ApplyTheme()
    end
    return Library._accent
end

function Library:ToggleUI()
    if Library.Window then Library.Window.ToggleUI() end
end
function Library:ShowUI()
    if Library.Window then Library.Window.ShowUI() end
end
function Library:HideUI()
    if Library.Window then Library.Window.HideUI() end
end

function Library:Rejoin()
    pcall(function()
        if game.JobId and game.JobId ~= "" then
            TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, LocalPlayer)
        else
            TeleportService:Teleport(game.PlaceId, LocalPlayer)
        end
    end)
end

function Library:CopyToClipboard(text)
    text = tostring(text or "")
    local fn = getClipboardFn()
    if fn then
        local ok = pcall(fn, text)
        if ok then
            Library:Notify({
                Title = "Copied",
                Content = "Copied to clipboard.",
                Type = "success",
                Duration = 2,
            })
            return true
        end
    end
    Library:Notify({
        Title = "Clipboard",
        Content = "Clipboard is not supported on this device.",
        Type = "warning",
        Duration = 3,
    })
    return false
end

function Library:Destroy()
    for _, c in ipairs(Library._connections) do
        pcall(function() c:Disconnect() end)
    end
    Library._connections = {}
    Library._keybinds = {}
    Library._notifs = {}
    Library._themeRefreshers = {}
    ActiveDrag = nil
    if Library._gui then
        pcall(function() Library._gui:Destroy() end)
    end
    Library._gui = nil
    Library._notifHolder = nil
    Library.Window = nil
end

return Library

