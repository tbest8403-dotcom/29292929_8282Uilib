local function detectPlatform()
    local touch = UserInputService.TouchEnabled
    local kb    = UserInputService.KeyboardEnabled
    if touch and not kb then
        return "Mobile"
    end
    local okTen, ten = pcall(function()
        return GuiService:IsTenFootInterface()
    end)
    if okTen and ten then
        return "Console"
    end
    if UserInputService.GamepadEnabled and not kb and not touch then
        return "Console"
    end
    return "PC"
end

