            PaddingTop = UDim.new(0, 10),
            PaddingBottom = UDim.new(0, 10),
            Parent = page,
        })

        tab._page = page
        tab._button = btn
        tab._pageInst = page

        function tab:_setSelected(selected)
            self._isSelected = selected
            if selected then
                Tween(btnBg, { BackgroundTransparency = 0 }, 0.15)
                Tween(indicator, { BackgroundTransparency = 0 }, 0.15)
                btnLabel.TextColor3 = resolveColor("Text")
                page.Visible = true
            else
                Tween(btnBg, { BackgroundTransparency = 1 }, 0.15)
                Tween(indicator, { BackgroundTransparency = 1 }, 0.15)
                btnLabel.TextColor3 = resolveColor("SubText")
                page.Visible = false
            end
        end
        tab:_setSelected(false)
        addRefresher(function()
            tab:_setSelected(tab._isSelected)
        end)

        Connect(btn.MouseEnter, function()
            if not tab._isSelected then
                Tween(btnBg, { BackgroundTransparency = 0.55 }, 0.12)
            end
        end)
        Connect(btn.MouseLeave, function()
            if not tab._isSelected then
                Tween(btnBg, { BackgroundTransparency = 1 }, 0.12)
            end
        end)
        Connect(btn.Activated, function()
            self:SelectTab(name)
        end)

        -- element methods
        function tab:CreateButton(c)      return createButton(self, c) end
        function tab:CreateToggle(c)      return createToggle(self, c) end
        function tab:CreateSlider(c)      return createSlider(self, c) end
        function tab:CreateDropdown(c)    return createDropdown(self, c) end
        function tab:CreateTextbox(c)     return createTextbox(self, c) end
        function tab:CreateKeybind(c)     return createKeybind(self, c) end
