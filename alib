--[[
============================================================================
    Modern UI Library  (single-file, mobile + PC)
    ------------------------------------------------------------------------
    A clean, compact, draggable, responsive Roblox GUI library for use in a
    LocalScript. Designed to be hosted on GitHub and loaded with HttpGet.

    LOAD:
        local Library = loadstring(game:HttpGet("YOUR_RAW_GITHUB_LINK"))()

    See the bottom of this file for full example usage.

    NOTE: This is a UI library + built-in utility options only. It contains
    no exploit / cheat features.
============================================================================
]]

local Library = {}
Library.__index = Library

