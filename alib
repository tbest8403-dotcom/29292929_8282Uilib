    function Window:_applyScale()
        local cam = workspace.CurrentCamera
        local vp = (cam and cam.ViewportSize) or Vector2.new(1280, 720)
        local baseW = size.X.Offset
        local baseH = size.Y.Offset
        local margin = IS_MOBILE and 18 or 36
        local sx = (vp.X - margin) / math.max(baseW, 1)
        local sy = (vp.Y - margin) / math.max(baseH, 1)
        local sc = math.min(1, sx, sy)
        if sc <= 0 then sc = 0.4 end
        self._targetScale = sc
        if not self._hidden and self._main.Visible then
            self._uiScale.Scale = sc
        end
    end

    function Window.ShowUI()
        Window._hidden = false
        Window._reopen.Visible = false
        Window._main.Visible = true
        Window._uiScale.Scale = 0
        Window:_applyScale()
        Tween(Window._uiScale, { Scale = Window._targetScale }, 0.22,
            Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    end

    function Window.HideUI()
        Window._hidden = true
        local tw = Tween(Window._uiScale, { Scale = 0 }, 0.18,
            Enum.EasingStyle.Quad, Enum.EasingDirection.In)
        tw.Completed:Once(function()
            if Window._hidden then
                Window._main.Visible = false
                Window._reopen.Visible = true
            end
        end)
    end

    function Window.ToggleUI()
        if Window._hidden then
            Window.ShowUI()
        else
            Window.HideUI()
        end
    end

    function Window:Destroy()
        Library:Destroy()
    end
    function Window:Notify(o)
        return Library:Notify(o)
    end

    -- Tab creation
