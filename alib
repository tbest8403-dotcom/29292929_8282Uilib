Library._connections   = {}   -- all RBXScriptConnections (cleaned on Destroy)
Library._themeObjects  = {}   -- {inst, prop, role} for live theme recolouring
Library._themeRefreshers = {} -- functions re-run on theme change (stateful colours)
Library._keybinds      = {}   -- registered keybind objects
Library._notifs        = {}   -- active notification records
Library._fps           = 60
Library._gui           = nil
Library._notifHolder   = nil
Library.Window         = nil

