-- Element building blocks
----------------------------------------------------------------------------
local function newElementFrame(tab, height)
    local frame = Create("Frame", {
        Name = "Element",
        Size = UDim2.new(1, 0, 0, height or 36),
        BorderSizePixel = 0,
        LayoutOrder = tab:_nextOrder(),
        Parent = tab._page,
    })
    Theme(frame, "BackgroundColor3", "Element")
    AddCorner(frame, 8)
    AddStroke(frame)
    return frame
end

local function elementLabel(parent, text)
    local lbl = Create("TextLabel", {
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 12, 0, 0),
        Size = UDim2.new(1, -90, 1, 0),
        Font = FONT_MED,
        Text = tostring(text or ""),
        TextSize = 14,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Center,
        TextTruncate = Enum.TextTruncate.AtEnd,
        Parent = parent,
    })
    Theme(lbl, "TextColor3", "Text")
    return lbl
end

-- Full-cover transparent button with hover/press visuals (PC + mobile).
local function makeInteractive(frame, onClick)
    local hovering = false
    local btn = Create("TextButton", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 1, 0),
        Text = "",
        AutoButtonColor = false,
        ZIndex = 2,
        Parent = frame,
    })
    local function toBase()
        Tween(frame, { BackgroundColor3 = resolveColor(hovering and "ElementHover" or "Element") }, 0.15)
    end
    Connect(btn.MouseEnter, function()
        hovering = true
        Tween(frame, { BackgroundColor3 = resolveColor("ElementHover") }, 0.15)
    end)
    Connect(btn.MouseLeave, function()
        hovering = false
        Tween(frame, { BackgroundColor3 = resolveColor("Element") }, 0.15)
    end)
    Connect(btn.InputBegan, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
            Tween(frame, { BackgroundColor3 = resolveColor("ElementHover") }, 0.08)
        end
    end)
    Connect(btn.InputEnded, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
            toBase()
        end
    end)
    if onClick then
        Connect(btn.Activated, function()
            onClick()
        end)
    end
    return btn
end

local function hoverFrame(frame, btn)
    Connect(btn.MouseEnter, function()
        Tween(frame, { BackgroundColor3 = resolveColor("ElementHover") }, 0.15)
    end)
    Connect(btn.MouseLeave, function()
        Tween(frame, { BackgroundColor3 = resolveColor("Element") }, 0.15)
    end)
end

-- Attach the shared element API (SetVisible / SetName / Destroy).
local function attachCommon(api, frame, label, onDestroy)
    function api:SetVisible(v)
        frame.Visible = v and true or false
        return api
    end
    function api:Destroy()
        if onDestroy then
            pcall(onDestroy)
        end
        pcall(function() frame:Destroy() end)
    end
    if label then
        function api:SetName(t)
            label.Text = tostring(t)
            return api
        end
    end
    return api
end

