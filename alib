        Size = UDim2.new(1, -24, 0, 6),
        BorderSizePixel = 0,
        Parent = frame,
    })
    Theme(track, "BackgroundColor3", "ToggleOff")
    AddCorner(track, 3)
    local fill = Create("Frame", {
        Size = UDim2.new(0, 0, 1, 0),
        BorderSizePixel = 0,
        Parent = track,
    })
    Theme(fill, "BackgroundColor3", "Accent")
    AddCorner(fill, 3)
    local knob = Create("Frame", {
        Size = UDim2.new(0, 14, 0, 14),
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(0, 0, 0.5, 0),
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        BorderSizePixel = 0,
        ZIndex = 2,
        Parent = track,
    })
    AddCorner(knob, 7)

    local function applyVisual()
        local lo, hi = math.min(min, max), math.max(min, max)
        local r = 0
        if hi > lo then
            r = (value - lo) / (hi - lo)
        end
        r = math.clamp(r, 0, 1)
        fill.Size = UDim2.new(r, 0, 1, 0)
        knob.Position = UDim2.new(r, 0, 0.5, 0)
        valueLabel.Text = tostring(value)
    end

    local function setValue(v, fire)
        local lo, hi = math.min(min, max), math.max(min, max)
        v = math.clamp(v, lo, hi)
        local steps = math.floor((v - min) / inc + 0.5)
        v = min + steps * inc
        v = math.clamp(v, lo, hi)
        v = tidyNumber(v, inc)
        value = v
        applyVisual()
        if fire then
            SafeCallback(cfg.Callback, value)
        end
    end

    local function updateFromInput(input)
        local denom = math.max(track.AbsoluteSize.X, 1)
        local r = math.clamp((input.Position.X - track.AbsolutePosition.X) / denom, 0, 1)
        setValue(min + (max - min) * r, true)
    end

    local hit = Create("TextButton", {
        BackgroundTransparency = 1,
        Text = "",
        AutoButtonColor = false,
        AnchorPoint = Vector2.new(0, 0.5),
        Position = UDim2.new(0, 0, 0.5, 0),
        Size = UDim2.new(1, 0, 0, 26),
        ZIndex = 3,
        Parent = track,
    })
    Connect(hit.InputBegan, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
            updateFromInput(input)
            ActiveDrag = { onMove = updateFromInput }
        end
    end)

    setValue(value, true) -- snap + render + apply default

    local api = {}
    function api:Set(v)
        setValue(tonumber(v) or value, true)
        return api
    end
    function api:Get()
        return value
    end
    function api:SetMin(v)
        min = tonumber(v) or min
        setValue(value, false)
        return api
    end
    function api:SetMax(v)
        max = tonumber(v) or max
        setValue(value, false)
        return api
    end
    attachCommon(api, frame, label)
    return api
end

local function createDropdown(tab, cfg)
    cfg = cfg or {}
    local multi = cfg.MultiSelect and true or false
    local options = {}
    for _, o in ipairs(cfg.Options or {}) do
        table.insert(options, o)
    end

    local selected = {}
    if type(cfg.Default) == "table" then
        for _, d in ipairs(cfg.Default) do selected[d] = true end
    elseif cfg.Default ~= nil then
        selected[cfg.Default] = true
    end

    local HEADER, ROW, MAXLIST = 36, 28, 132
    local open = false

    local frame = newElementFrame(tab, HEADER)
    frame.Name = "Dropdown"
    frame.ClipsDescendants = true

    local label = Create("TextLabel", {
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 12, 0, 0),
        Size = UDim2.new(0, 150, 0, HEADER),
        Font = FONT_MED,
        Text = cfg.Name or "Dropdown",
        TextSize = 14,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextTruncate = Enum.TextTruncate.AtEnd,
        Parent = frame,
    })
    Theme(label, "TextColor3", "Text")

    local valueLabel = Create("TextLabel", {
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 150, 0, 0),
        Size = UDim2.new(1, -184, 0, HEADER),
        Font = FONT,
        Text = "",
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Right,
        TextTruncate = Enum.TextTruncate.AtEnd,
        Parent = frame,
    })
    Theme(valueLabel, "TextColor3", "SubText")

    local arrow = Create("TextLabel", {
        BackgroundTransparency = 1,
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, -14, 0, HEADER / 2),
        Size = UDim2.new(0, 14, 0, 14),
        Font = FONT_BOLD,
        Text = "v",
        TextSize = 12,
        Parent = frame,
    })
    Theme(arrow, "TextColor3", "SubText")

    local list = Create("ScrollingFrame", {
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Position = UDim2.new(0, 6, 0, HEADER + 2),
        Size = UDim2.new(1, -12, 0, 0),
        CanvasSize = UDim2.new(),
        ScrollBarThickness = 3,
        ScrollingDirection = Enum.ScrollingDirection.Y,
        ZIndex = 2,
        Parent = frame,
    })
    Theme(list, "ScrollBarImageColor3", "ScrollBar")
    Create("UIListLayout", {
        Padding = UDim.new(0, 3),
        SortOrder = Enum.SortOrder.LayoutOrder,
        Parent = list,
    })

    local headBtn = Create("TextButton", {
        BackgroundTransparency = 1,
        Text = "",
        AutoButtonColor = false,
        Position = UDim2.new(0, 0, 0, 0),
        Size = UDim2.new(1, 0, 0, HEADER),
        ZIndex = 4,
        Parent = frame,
    })
    hoverFrame(frame, headBtn)

    local function summary()
        local picks = {}
        for _, o in ipairs(options) do
            if selected[o] then table.insert(picks, tostring(o)) end
        end
        if #picks == 0 then
            return "None"
        end
        if multi then
            if #picks <= 2 then
                return table.concat(picks, ", ")
            end
            return tostring(#picks) .. " selected"
        end
        return picks[1]
    end

    local function buildResult()
        if multi then
            local r = {}
            for _, o in ipairs(options) do
                if selected[o] then table.insert(r, o) end
            end
            return r
        end
        for _, o in ipairs(options) do
            if selected[o] then return o end
        end
        return nil
    end

    local function listFullHeight()
        local n = #options
        if n == 0 then return 0 end
        return n * ROW + (n - 1) * 3
    end

    local function setOpen(state)
        open = state
        local full = listFullHeight()
        local visible = math.min(full, MAXLIST)
        list.CanvasSize = UDim2.new(0, 0, 0, full)
        if open then
            Tween(frame, { Size = UDim2.new(1, 0, 0, HEADER + 2 + visible + 6) }, 0.18)
            Tween(list, { Size = UDim2.new(1, -12, 0, visible) }, 0.18)
            Tween(arrow, { Rotation = 180 }, 0.18)
        else
            Tween(frame, { Size = UDim2.new(1, 0, 0, HEADER) }, 0.18)
            Tween(list, { Size = UDim2.new(1, -12, 0, 0) }, 0.18)
            Tween(arrow, { Rotation = 0 }, 0.18)
        end
    end

    local rowFrames, ticks = {}, {}

    local function rebuildRows()
        for _, b in ipairs(rowFrames) do
            pcall(function() b:Destroy() end)
        end
        rowFrames, ticks = {}, {}
        for idx, o in ipairs(options) do
            local rb = Create("TextButton", {
                Size = UDim2.new(1, 0, 0, ROW),
                BorderSizePixel = 0,
                Text = "",
                AutoButtonColor = false,
                LayoutOrder = idx,
                ZIndex = 2,
                Parent = list,
            })
            Theme(rb, "BackgroundColor3", "Section")
            AddCorner(rb, 6)
            local rl = Create("TextLabel", {
                BackgroundTransparency = 1,
                Position = UDim2.new(0, 10, 0, 0),
                Size = UDim2.new(1, -32, 1, 0),
                Font = FONT,
                Text = tostring(o),
                TextSize = 13,
                TextXAlignment = Enum.TextXAlignment.Left,
                TextTruncate = Enum.TextTruncate.AtEnd,
                ZIndex = 2,
                Parent = rb,
            })
            Theme(rl, "TextColor3", "Text")
            local tick = Create("TextLabel", {
                BackgroundTransparency = 1,
                AnchorPoint = Vector2.new(1, 0.5),
                Position = UDim2.new(1, -8, 0.5, 0),
                Size = UDim2.new(0, 16, 0, 16),
                Font = FONT_BOLD,
                Text = selected[o] and "+" or "",
                TextSize = 14,
                ZIndex = 2,
                Parent = rb,
            })
            Theme(tick, "TextColor3", "Accent")
            ticks[o] = tick

            Connect(rb.MouseEnter, function()
                Tween(rb, { BackgroundColor3 = resolveColor("ElementHover") }, 0.12)
            end)
            Connect(rb.MouseLeave, function()
                Tween(rb, { BackgroundColor3 = resolveColor("Section") }, 0.12)
            end)
            Connect(rb.Activated, function()
                if multi then
                    selected[o] = not selected[o] or nil
                else
                    for k in pairs(selected) do selected[k] = nil end
                    selected[o] = true
                end
                for opt, tk in pairs(ticks) do
                    tk.Text = selected[opt] and "+" or ""
                end
                valueLabel.Text = summary()
                SafeCallback(cfg.Callback, buildResult())
                if not multi then
                    setOpen(false)
                end
            end)

            table.insert(rowFrames, rb)
        end
        valueLabel.Text = summary()
        if open then
            setOpen(true)
        end
    end

    Connect(headBtn.Activated, function()
        setOpen(not open)
    end)

    rebuildRows()
    setOpen(false)
    if buildResult() ~= nil then
        SafeCallback(cfg.Callback, buildResult())
    end

    local api = {}
    function api:Set(v)
        for k in pairs(selected) do selected[k] = nil end
        if type(v) == "table" then
            for _, x in ipairs(v) do selected[x] = true end
        elseif v ~= nil then
            selected[v] = true
        end
        for opt, tk in pairs(ticks) do
            tk.Text = selected[opt] and "+" or ""
        end
        valueLabel.Text = summary()
        SafeCallback(cfg.Callback, buildResult())
        return api
    end
    function api:Get()
        return buildResult()
    end
    function api:Refresh(newOptions)
        options = {}
        for _, o in ipairs(newOptions or {}) do
            table.insert(options, o)
        end
        local valid = {}
        for _, o in ipairs(options) do valid[o] = true end
        for k in pairs(selected) do
            if not valid[k] then selected[k] = nil end
        end
        rebuildRows()
        return api
    end
    function api:AddOption(o)
        table.insert(options, o)
        rebuildRows()
        return api
    end
    function api:RemoveOption(o)
        for i, v in ipairs(options) do
            if v == o then
                table.remove(options, i)
                break
            end
        end
        selected[o] = nil
        rebuildRows()
        return api
    end
    attachCommon(api, frame, label)
    return api
end

