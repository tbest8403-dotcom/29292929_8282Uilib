----------------------------------------------------------------------------
-- Low-level helpers
----------------------------------------------------------------------------
local function Create(class, props, children)
    local inst = Instance.new(class)
    if props then
        for k, v in pairs(props) do
            if k ~= "Parent" then
                inst[k] = v
            end
        end
        if props.Parent ~= nil then
            inst.Parent = props.Parent
        end
    end
    if children then
        for _, c in ipairs(children) do
            c.Parent = inst
        end
    end
    return inst
end

local function AddCorner(inst, radius)
    return Create("UICorner", {
        CornerRadius = UDim.new(0, radius or 8),
        Parent = inst,
    })
end

local function AddPadding(inst, left, right, top, bottom)
    return Create("UIPadding", {
        PaddingLeft   = UDim.new(0, left or 0),
        PaddingRight  = UDim.new(0, right or left or 0),
        PaddingTop    = UDim.new(0, top or 0),
        PaddingBottom = UDim.new(0, bottom or top or 0),
        Parent = inst,
    })
end

local function Tween(inst, props, dur, style, dir)
    local info = TweenInfo.new(
        dur or 0.18,
        style or Enum.EasingStyle.Quad,
        dir or Enum.EasingDirection.Out
    )
    local tw = TweenService:Create(inst, info, props)
    tw:Play()
    return tw
end

local function SafeCallback(fn, ...)
    if type(fn) ~= "function" then
        return
    end
    local args = { ... }
    local n = select("#", ...)
    task.spawn(function()
        local ok, err = pcall(function()
            fn(table.unpack(args, 1, n))
        end)
        if not ok then
            warn("[ModernUILib] Callback error: " .. tostring(err))
        end
    end)
end

local function getClipboardFn()
    if type(setclipboard) == "function" then
        return setclipboard
    end
    if type(toclipboard) == "function" then
        return toclipboard
    end
    if type(set_clipboard) == "function" then
        return set_clipboard
    end
    if syn and type(syn.write_clipboard) == "function" then
        return syn.write_clipboard
    end
    return nil
end

local function getPing()
    local ok, ping = pcall(function()
        return math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue())
    end)
    if ok and ping then
        return ping
    end
    return 0
end

local function decimalsOf(n)
    local s = tostring(n)
    local dot = string.find(s, "%.")
    if not dot then
        return 0
    end
    return #s - dot
end

local function tidyNumber(n, inc)
    local d = decimalsOf(inc)
    local mult = 10 ^ d
    return math.floor(n * mult + 0.5) / mult
end

local function Connect(signal, fn)
    local ok, conn = pcall(function()
        return signal:Connect(fn)
    end)
    if ok and conn then
        table.insert(Library._connections, conn)
        return conn
    end
    return nil
end

----------------------------------------------------------------------------
-- Theming engine
----------------------------------------------------------------------------
local function resolveColor(role)
    if role == "Accent" then
        return Library._accent or Color3.fromRGB(120, 80, 255)
    end
    local t = Library._theme or Themes.Dark
    return t[role] or Color3.fromRGB(255, 0, 255)
end

-- Register an instance property to follow the current theme.
local function Theme(inst, prop, role)
    inst[prop] = resolveColor(role)
    table.insert(Library._themeObjects, { inst, prop, role })
    return inst
end

local function addRefresher(fn)
    table.insert(Library._themeRefreshers, fn)
end

local function ApplyTheme()
    for _, e in ipairs(Library._themeObjects) do
        local inst, prop, role = e[1], e[2], e[3]
        pcall(function()
            if inst and inst.Parent ~= nil then
                inst[prop] = resolveColor(role)
            end
        end)
    end
    for _, fn in ipairs(Library._themeRefreshers) do
        pcall(fn)
    end
end

local function AddStroke(inst, thickness)
    local s = Create("UIStroke", {
        Thickness = thickness or 1,
        ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
        Parent = inst,
    })
    Theme(s, "Color", "Stroke")
    return s
end

----------------------------------------------------------------------------
-- Global drag + input dispatch (single source of truth)
----------------------------------------------------------------------------
local ActiveDrag = nil  -- { onMove = function(input), onEnd = function(input) }

Connect(UserInputService.InputChanged, function(input)
    if ActiveDrag and ActiveDrag.onMove then
        if input.UserInputType == Enum.UserInputType.MouseMovement
            or input.UserInputType == Enum.UserInputType.Touch then
            pcall(ActiveDrag.onMove, input)
        end
    end
end)

Connect(UserInputService.InputEnded, function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
        if ActiveDrag then
            if ActiveDrag.onEnd then
                pcall(ActiveDrag.onEnd, input)
            end
            ActiveDrag = nil
        end
    end
end)

-- Keybind handler (one global listener for all keybinds)
Connect(UserInputService.InputBegan, function(input, gameProcessed)
    if input.UserInputType ~= Enum.UserInputType.Keyboard then
        return
    end
    -- Capture mode (rebinding) takes priority and ignores gameProcessed.
    for _, kb in ipairs(Library._keybinds) do
        if kb.listening then
            if input.KeyCode == Enum.KeyCode.Escape then
                kb.kc = nil
            else
                kb.kc = input.KeyCode
            end
            kb.listening = false
            kb.render()
            return
        end
    end
    if gameProcessed then
        return
    end
    for _, kb in ipairs(Library._keybinds) do
        if kb.kc and input.KeyCode == kb.kc then
            kb.fire()
        end
    end
end)

-- FPS counter
do
    local frames, lastT = 0, os.clock()
    Connect(RunService.RenderStepped, function()
        frames = frames + 1
        local now = os.clock()
        if now - lastT >= 0.5 then
            Library._fps = math.floor(frames / (now - lastT) + 0.5)
            frames = 0
            lastT = now
        end
    end)
end

----------------------------------------------------------------------------
-- ScreenGui creation (handles duplicates + parenting)
----------------------------------------------------------------------------
local function getGui()
    if Library._gui and Library._gui.Parent then
        return Library._gui
    end

    -- Remove any leftover GUI from a previous run.
    pcall(function()
        local pg = LocalPlayer:FindFirstChildOfClass("PlayerGui")
        if pg then
            local old = pg:FindFirstChild(GUI_NAME)
            if old then old:Destroy() end
        end
    end)
    pcall(function()
        local cg = game:GetService("CoreGui")
        if cg then
            local old = cg:FindFirstChild(GUI_NAME)
            if old then old:Destroy() end
        end
    end)
    pcall(function()
        if gethui then
            local h = gethui()
            if h then
                local old = h:FindFirstChild(GUI_NAME)
                if old then old:Destroy() end
            end
        end
    end)

    local gui = Create("ScreenGui", {
        Name = GUI_NAME,
        ResetOnSpawn = false,
        IgnoreGuiInset = true,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        DisplayOrder = 9999,
    })
    pcall(function() gui.ScreenInsets = Enum.ScreenInsets.None end)

    -- Optional executor GUI protection.
    pcall(function()
        if syn and syn.protect_gui then syn.protect_gui(gui) end
    end)
    pcall(function()
        if protect_gui then protect_gui(gui) end
    end)

    -- Parent (executor first, fall back to PlayerGui).
    local parented = false
    if gethui then
        local ok = pcall(function() gui.Parent = gethui() end)
        if ok and gui.Parent then parented = true end
    end
    if not parented then
        local ok = pcall(function() gui.Parent = game:GetService("CoreGui") end)
        if ok and gui.Parent then parented = true end
    end
    if not parented then
        pcall(function() gui.Parent = LocalPlayer:WaitForChild("PlayerGui") end)
    end

    Library._gui = gui

    -- Notification holder
    Library._notifHolder = Create("Frame", {
        Name = "Notifications",
        AnchorPoint = Vector2.new(1, 1),
        Position = UDim2.new(1, -12, 1, -12),
        Size = UDim2.new(0, 290, 1, -24),
        BackgroundTransparency = 1,
        Parent = gui,
        ZIndex = 80,
    })

    return gui
end

----------------------------------------------------------------------------
-- Notifications
----------------------------------------------------------------------------
local function reflowNotifs()
    local y = -6
    for i = #Library._notifs, 1, -1 do
        local r = Library._notifs[i]
        if r.frame and r.frame.Parent then
            Tween(r.frame, { Position = UDim2.new(1, 0, 1, y) }, 0.22)
            y = y - (r.height + 8)
        end
    end
end

function Library:Notify(opts)
    opts = opts or {}
    getGui()
    local holder = Library._notifHolder
    if not holder then
        return
    end

    local nType   = opts.Type or "info"
    local dur      = tonumber(opts.Duration) or 3
    local titleTxt = tostring(opts.Title or "Notification")
    local bodyTxt  = tostring(opts.Content or "")

    local accent = resolveColor("Accent")
    if nType == "success" then
        accent = resolveColor("Success")
    elseif nType == "warning" then
        accent = resolveColor("Warning")
    elseif nType == "error" then
        accent = resolveColor("Error")
    end

    local hasBody = bodyTxt ~= ""
    local width   = 280
    local height  = hasBody and 64 or 44

    local notif = Create("Frame", {
        Size = UDim2.new(0, width, 0, height),
        AnchorPoint = Vector2.new(1, 1),
        Position = UDim2.new(1, width + 40, 1, 0),
        BorderSizePixel = 0,
        Parent = holder,
        ZIndex = 81,
    })
    notif.BackgroundColor3 = resolveColor("Notif")
    AddCorner(notif, 8)
    local st = Create("UIStroke", { Thickness = 1, Parent = notif })
    st.Color = resolveColor("Stroke")

    Create("Frame", {  -- accent stripe
        Size = UDim2.new(0, 4, 1, -14),
        Position = UDim2.new(0, 6, 0.5, 0),
        AnchorPoint = Vector2.new(0, 0.5),
        BorderSizePixel = 0,
        BackgroundColor3 = accent,
        ZIndex = 82,
        Parent = notif,
    }, { Create("UICorner", { CornerRadius = UDim.new(0, 2) }) })

    Create("TextLabel", {
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 18, 0, 8),
        Size = UDim2.new(1, -28, 0, 16),
        Font = FONT_BOLD,
        TextSize = 13,
        Text = titleTxt,
        TextColor3 = resolveColor("Text"),
        TextXAlignment = Enum.TextXAlignment.Left,
        TextTruncate = Enum.TextTruncate.AtEnd,
        ZIndex = 82,
        Parent = notif,
    })

    if hasBody then
        Create("TextLabel", {
            BackgroundTransparency = 1,
            Position = UDim2.new(0, 18, 0, 26),
            Size = UDim2.new(1, -28, 0, 28),
            Font = FONT,
            TextSize = 12,
            Text = bodyTxt,
            TextColor3 = resolveColor("SubText"),
            TextWrapped = true,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextYAlignment = Enum.TextYAlignment.Top,
            TextTruncate = Enum.TextTruncate.AtEnd,
            ZIndex = 82,
            Parent = notif,
        })
    end

    local prog = Create("Frame", {
        Size = UDim2.new(1, -12, 0, 2),
        Position = UDim2.new(0, 6, 1, -5),
        BorderSizePixel = 0,
        BackgroundColor3 = accent,
        ZIndex = 82,
        Parent = notif,
    })
    AddCorner(prog, 1)

    local closeBtn = Create("TextButton", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 1, 0),
        Text = "",
        AutoButtonColor = false,
        ZIndex = 83,
        Parent = notif,
    })

    local record = { frame = notif, height = height, width = width, alive = true }
    table.insert(Library._notifs, record)
    reflowNotifs()

    Tween(prog, { Size = UDim2.new(0, 0, 0, 2) }, dur, Enum.EasingStyle.Linear)

    local function dismiss()
        if not record.alive then
            return
        end
        record.alive = false
        for i, r in ipairs(Library._notifs) do
            if r == record then
                table.remove(Library._notifs, i)
                break
            end
        end
        pcall(function()
            Tween(notif, {
                Position = UDim2.new(1, width + 40, notif.Position.Y.Scale, notif.Position.Y.Offset),
                BackgroundTransparency = 1,
            }, 0.2)
        end)
        task.delay(0.22, function()
            pcall(function() notif:Destroy() end)
        end)
        reflowNotifs()
    end

    Connect(closeBtn.Activated, dismiss)
    task.delay(dur, dismiss)

    return record
end

