            Size = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            BorderSizePixel = 0,
            Parent = btn,
        })
        Theme(btnBg, "BackgroundColor3", "Element")
        AddCorner(btnBg, 6)
